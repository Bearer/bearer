{
  "extends": "@bearer/tslint-config",
  "rules": {
    "object-curly-spacing": [true, "always"],
    "no-console": false,
    "variable-name": [true, "ban-keywords", "check-format", "allow-leading-underscore", "allow-pascal-case"]
  },
  "linterOptions": {
    "exclude": [
      "**/node_modules/**",
      "**/templates/**",
      "packages/react/dummy/**",
      "**/__fixtures__/**",
      "**/lib/**",
      "**/www/**",
      "package.json",
      ".github/PULL_REQUEST_TEMPLATE.md"
    ]
  }
}
