{
  "name": "@bearer/x-ray",
  "version": "0.100.0",
  "description": "Trace outgoing traffic inside the intent",
  "main": "index.js",
  "license": "MIT",
  "dependencies": {
    "@bearer/logger": "^0.95.1",
    "@bearer/package-init": "^0.95.1",
    "@bearer/tsconfig": "^0.95.1",
    "@bearer/tslint-config": "^0.95.1",
    "@types/uuid": "^3.4.4",
    "uuid": "^3.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^7.5.2",
    "@commitlint/config-conventional": "^7.5.0",
    "@types/debug": "^4.1.2",
    "@types/jest": "^24.0.9",
    "aws-sdk": "^2.415.0",
    "commitlint": "^7.5.2",
    "cz-conventional-changelog": "^2.1.0",
    "husky": "^1.3.1",
    "jest": "^24.1.0",
    "lint-staged": "^8.1.5",
    "prettier": "^1.16.4",
    "ts-jest": "^24.0.0",
    "tslint": "^5.13.1",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^3.3.3333"
  },
  "lint-staged": {
    "*.{css,md,tsx,ts}": [
      "prettier --write",
      "tslint -c tslint.json --fix",
      "git add"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "scripts": {
    "start": "tsc --watch",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf lib",
    "prepack": "yarn clean && yarn build",
    "prepare": "yarn clean && yarn build",
    "test": "jest",
    "test:ci": "jest --coverage"
  }
}
