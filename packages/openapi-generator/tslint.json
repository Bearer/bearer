{
  "defaultSeverity": "error",
  "extends": ["@oclif/tslint", "tslint-config-prettier"],
  "jsRules": {},
  "rules": {
    "object-curly-spacing": [true, "always"],
    "no-console": false,
    "no-bitwise": false
  },
  "rulesDirectory": [],

  "linterOptions": {
    "exclude": ["__tests__/__fixtures__/**/*"]
  }
}
