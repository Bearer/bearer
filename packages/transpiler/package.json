{
  "name": "@bearer/transpiler",
  "version": "0.0.1",
  "description": "Bearer transpiler",
  "main": "dist/main.js",
  "types": "dist/index.d.ts",
  "module": "dist/main.es.js",
  "author": "Bearer",
  "license": "UNLICENSED",
  "files": ["dist/"],
  "scripts": {
    "start": "yarn build",
    "build": "per-env",
    "build:bundle": "rollup -c",
    "build:development": "yarn build:bundle -w",
    "build:production": "NODE_ENV=production yarn build:bundle",
    "prepublish": "yarn build:production",
    "prepublishOnly":
      "BUILD=distribution NODE_ENV=production yarn build:production",
    "test": "jest"
  },
  "jest": {
    "moduleFileExtensions": ["ts", "tsx", "js"],
    "transform": {
      "^.+\\.(ts|tsx)$": "<rootDir>/preprocessor.js"
    },
    "testMatch": ["**/__tests__/*.+(ts|tsx|js)"],
    "setupFiles": ["./jest.setup.js"]
  },
  "repository": {
    "type": "git",
    "url": "github:Bearer/bearer"
  },
  "devDependencies": {
    "@types/jest": "^23.1.1",
    "@types/node": "9.6.7",
    "dotenv": "^6.0.0",
    "jest": "^23.1.0",
    "per-env": "^1.0.2",
    "rollup": "^0.61.1",
    "rollup-plugin-commonjs": "^9.1.3",
    "rollup-plugin-copy": "^0.2.3",
    "rollup-plugin-html-entry": "^0.2.0",
    "rollup-plugin-node-resolve": "^3.3.0",
    "rollup-plugin-terser": "^1.0.1",
    "rollup-plugin-typescript2": "^0.15.0",
    "rollup-watch": "^4.3.1",
    "ts-jest": "^22.4.6"
  },
  "dependencies": {
    "fs-extra": "^6.0.1",
    "typescript": "^2.9.2"
  }
}
