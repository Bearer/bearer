{
  "name": "@bearer/types",
  "version": "0.58.5",
  "description": "Provide typing for Bearer packages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "clean": "rm -rf dist/",
    "test": "jest",
    "prepare": "rm -rf dist/ && NODE_ENV=production tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bearer/bearer.git"
  },
  "keywords": [
    "types",
    "typescript",
    "bearer"
  ],
  "author": "Bearer Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Bearer/bearer/issues"
  },
  "homepage": "https://github.com/Bearer/bearer#readme",
  "devDependencies": {
    "@types/jest": "^23.3.1",
    "jest": "^23.5.0",
    "ts-jest": "^23.1.3",
    "typescript": "^3.0.1"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
}
